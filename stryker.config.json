{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/parser/nestjs/**/*.ts"
  ],
  "testRunnerNodeArgs": [],
  "thresholds": {
    "high": 80,
    "low": 75,
    "break": 75
  },
  "reporters": ["progress", "clear-text", "html"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  }
}
